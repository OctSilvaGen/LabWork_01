
const int ENCA = 2;           // Пин A энкодера (сигнал фазы)
const int ENCB = 3;           // Пин B энкодера (определение направления)
const int BTN = 4;            // Пин кнопки энкодера
const int LED[] = {9, 10, 11}; // Пины светодиодов: 9=Красный, 10=Зеленый, 11=Синий

int color = 0;                // Текущий индекс цвета (0: Красный, 1: Зеленый, 2: Синий)
int bright = 128;             // Текущая яркость (0-255), старт с половины
int lastA = HIGH;             // Предыдущее состояние пина A (для детекции вращения)

int colors[3][3] = {
  {255, 0, 0},   // 0: Чистый красный
  {0, 255, 0},   // 1: Чистый зеленый
  {0, 0, 255}    // 2: Чистый синий
};

void setup() {
  // Настройка пинов энкодера и кнопки как входы с внутренней подтяжкой к +5В
  pinMode(ENCA, INPUT_PULLUP);
  pinMode(ENCB, INPUT_PULLUP);
  pinMode(BTN, INPUT_PULLUP);
  
  // Настройка пинов светодиодов как выходы
  for(int i = 0; i < 3; i++) {
    pinMode(LED[i], OUTPUT);
  }
}

void loop() {
  // Считываем текущее состояние пина A
  int a = digitalRead(ENCA);
  
  // Проверяем, нажата ли кнопка (LOW означает нажатие из-за подтяжки)
  bool pressed = (digitalRead(BTN) == LOW);
  
  // Логика обнаружения вращения:
  // 1. Состояние пина A изменилось по сравнению с прошлым циклом (lastA)
  // 2. Состояние пина B НЕ равно состоянию A (это определяет направление)
  if(a != lastA && digitalRead(ENCB) != a) {
    
    if(pressed) {
      // РЕЖИМ ЯРКОСТИ (кнопка нажата)
      // Увеличиваем яркость на 5 единиц при каждом шаге вращения
      // constrain ограничивает значение диапазоном от 0 до 255
      bright = constrain(bright + 5, 0, 255);
    } else {
      // РЕЖИМ ВЫБОРА ЦВЕТА (кнопка отпущена)
      delay(100); // Небольшая задержка, чтобы цвет не переключался слишком быстро
      // Меняем индекс цвета: 0->1->2->0...
      color = (color + 1) % 3;
    }
    // Вычисляем реальную яркость для каждого канала:
    // map() пересчитывает текущую яркость (0-255) в диапазон конкретного цвета (0 или 255)
    analogWrite(LED[0], map(bright, 0, 255, 0, colors[color][0])); // Красный
    analogWrite(LED[1], map(bright, 0, 255, 0, colors[color][1])); // Зеленый
    analogWrite(LED[2], map(bright, 0, 255, 0, colors[color][2])); // Синий
  }
  
  // Запоминаем текущее состояние пина A для следующего цикла
  lastA = a;
}
